# Smart Displays — Environment variables
# Copy this to .env and fill in the values

# PostgreSQL (Supabase Session Pooler recommended)
DATABASE_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-eu.pooler.supabase.com:5432/postgres

# JWT Secret (generate a long random string)
SECRET_KEY=change-me-to-a-long-random-secret

# CORS — your Netlify frontend URL
CORS_ORIGINS=http://localhost:3000,https://displays.getapp.ro

# Cloudflare R2 Storage (optional — falls back to local /uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=smart-displays-media
R2_PUBLIC_URL=https://pub-xxx.r2.dev
